# 🔐 SETUP GUIDE - Configuración Local Segura
# 
# Este archivo es un EJEMPLO. Debes crear .env.local con tus propias credenciales.
# NUNCA commitees .env.local a GitHub - Ya está en .gitignore
#
# Pasos:
# 1. Copia este archivo a .env.local
# 2. Completa los valores con tus credenciales de Supabase
# 3. NUNCA compartas .env.local

# ========================================
# Supabase Configuration (Public - Safe)
# ========================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_anon_YOUR_LONG_ANON_KEY_HERE

# Obtén estos valores de:
# https://supabase.com/dashboard/project/[YOUR_PROJECT_ID]/settings/api
# - URL: Project URL
# - Anon key: `sb_anon_` key (public - safe for frontend)

# ========================================
# Supabase Service Role Key (PRIVATE!)
# ========================================
SUPABASE_SERVICE_ROLE_KEY=sb_secret_YOUR_LONG_SERVICE_KEY_HERE
SUPABASE_PROJECT_ID=your-project-id

# ⚠️  ADVERTENCIA: 
# - El Service Role Key es PRIVADO - Nunca lo compartas
# - Obtén en: https://supabase.com/dashboard/project/[YOUR_PROJECT_ID]/settings/api
# - Bajo "Service role key"
# - Si lo expones, regenera inmediatamente en Supabase Dashboard

# ========================================
# OpenAI Configuration (Optional)
# ========================================
OPENAI_API_KEY=sk_test_YOUR_OPENAI_KEY_HERE

# Para generar comentarios IA en reportes (Fase 2)
# Obtén en: https://platform.openai.com/account/api-keys

# ========================================
# Environment & Base URL
# ========================================
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ========================================
# Testing Data (Optional)
# ========================================
# Test users se crean con:
# npx ts-node scripts/create-users-api.ts
# o usar los scripts: create-test-users.sh o create-test-users.ps1

# ========================================
# ClickUp Integration (Optional)
# ========================================

# Clave de 32 bytes (64 hex chars) para cifrar la API key de ClickUp.
# Genera con: openssl rand -hex 32
# ⚠️  Si cambias esta clave, la API key almacenada quedará indescifrable.
CLICKUP_ENCRYPTION_KEY=

# Secreto que protege el endpoint del cron job de sincronización.
# Vercel lo envía automáticamente; aquí lo defines para pruebas locales.
# Genera con: openssl rand -base64 32
CRON_SECRET=
