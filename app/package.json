{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.15.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:headed": "pnpm exec playwright test --headed",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "lighthouse": "lhci autorun",
    "lighthouse:collect": "lhci collect",
    "lighthouse:assert": "lhci assert",
    "precheck": "pnpm lint",
    "precheck:ci": "pnpm lint && pnpm exec jest --ci --forceExit",
    "verify": "pnpm lint && pnpm test && pnpm test:e2e && pnpm build"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.93.3",
    "@tanstack/react-query": "^5.90.20",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "jose": "^6.1.3",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "next": "^16.2.6",
    "openai": "^6.17.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.71.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@faker-js/faker": "^10.3.0",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.39.3",
    "eslint-config-next": "^0.2.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lighthouse": "^13.0.3",
    "lint-staged": "^15.2.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "ts-jest": "^29.0.0",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["core-js", "esbuild", "sharp", "unrs-resolver"],
    "allowedDeprecatedVersions": {
      "@ungap/structured-clone": "1",
      "glob": "7 || 10",
      "inflight": "1",
      "rimraf": "2 || 3",
      "uuid": "8",
      "whatwg-encoding": "3"
    }
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  }
}
